@app.route('/trigger_adhoc_action', methods=['POST'])

@login_required

def trigger_adhoc_action():

    data = request.get_json()

    checkout_name = data.get('name')

    run_type = "Adhoc"

    user_email = session.get('user')

    user_name = session.get('employee_id')

    user_first_name = session.get('first_name')

    user_last_name = session.get('last_name')

    full_name = str(user_first_name + " " + user_last_name)

    if not user_email:

        return jsonify({"success": False, "error": "User session not found"}), 401

    # 1. Look up the specific subject

    subject = ADHOC_SUBJECT_MAP.get(checkout_name, None)

    if subject is not None:

        try:

            # 2. Call your email function

            # Sender is the logged-in user email

            send_adhoc_email(

                subject=subject,

                sender=user_email,

                sender_name=full_name

            )

            current_date = datetime.now().strftime('%m/%d/%Y')

            current_time = datetime.now().strftime('%H:%M:%S')

            status = "IN-PROGRESS"

            conn = sqlite3.connect(DATABASE_PATH)

            cur = conn.cursor()

            # Logic: "Scheduled" if run matches, else NULL

            requested_by = user_name if user_name else None

            cur.execute("""

                INSERT INTO digital_checkout_details

                (checkout_name, checkout_date, run_type, reported_time, checkout_status, requested_by)

                VALUES (?, ?, ?, ?, ?, ?)

                ON CONFLICT(checkout_name, run_type)

                DO UPDATE SET

                    reported_time=excluded.reported_time,

                    checkout_date=excluded.checkout_date,

                    checkout_status=excluded.checkout_status,

                    requested_by=excluded.requested_by

                """,

                (checkout_name, current_date, run_type, current_time, status, requested_by))

            conn.commit()

            conn.close()

            # 3. Return user name for the UI update

            return jsonify({"success": True, "user_name": user_name})

        except Exception as e:

            return jsonify({"success": False, "error": str(e)}), 500

    else:

        return jsonify({"success": False, "error": "Subject details not found"}), 500
 
