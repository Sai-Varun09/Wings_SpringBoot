<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TCS Healthcare — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --teal:      #0A7C6E;
    --teal-lt:   #12A090;
    --teal-dk:   #065248;
    --sky:       #EAF7F5;
    --accent:    #F4A836;
    --danger:    #E05252;
    --success:   #2ECC8B;
    --ink:       #0F1F1D;
    --muted:     #6B8A87;
    --line:      #D4ECEA;
    --white:     #FFFFFF;
    --sidebar-w: 240px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--sky);
    color: var(--ink);
    min-height: 100vh;
    display: flex;
    overflow-x: hidden;
  }

  /* ── SIDEBAR ──────────────────────────────────────── */
  .sidebar {
    width: var(--sidebar-w);
    background: var(--teal-dk);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0;
    height: 100vh;
    z-index: 100;
  }

  .sidebar-logo {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; gap: 12px;
  }
  .logo-icon {
    width: 36px; height: 36px;
    background: var(--accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: var(--ink);
    flex-shrink: 0;
  }
  .logo-text { color: #fff; font-size: 13px; line-height: 1.3; }
  .logo-text strong { display: block; font-size: 15px; letter-spacing: .3px; }

  nav { flex: 1; padding: 16px 0; overflow-y: auto; }

  .nav-section { margin-bottom: 4px; }
  .nav-label {
    font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    padding: 8px 24px 4px;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 24px;
    color: rgba(255,255,255,.65);
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all .2s;
  }
  .nav-item:hover, .nav-item.active {
    background: rgba(255,255,255,.07);
    color: #fff;
    border-left-color: var(--accent);
  }
  .nav-item svg { flex-shrink: 0; opacity: .8; }
  .nav-badge {
    margin-left: auto;
    background: var(--danger);
    color: #fff;
    font-size: 10px; font-weight: 600;
    padding: 2px 6px; border-radius: 10px;
  }

  .sidebar-footer {
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; gap: 10px;
  }
  .avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--teal-lt);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 600; font-size: 12px; flex-shrink: 0;
  }
  .user-name { color: #fff; font-size: 13px; font-weight: 500; }
  .user-role { color: rgba(255,255,255,.4); font-size: 11px; }

  /* ── MAIN ─────────────────────────────────────────── */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── TOPBAR ───────────────────────────────────────── */
  .topbar {
    background: var(--white);
    padding: 0 32px;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--line);
    position: sticky; top: 0; z-index: 50;
  }
  .page-title { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--ink); }
  .page-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }
  .topbar-right { display: flex; align-items: center; gap: 16px; }

  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: var(--sky); border: 1px solid var(--line);
    border-radius: 8px; padding: 8px 14px;
    font-size: 13px; color: var(--muted);
    cursor: text; transition: border-color .2s; width: 200px;
  }
  .search-box:focus-within { border-color: var(--teal); }
  .search-box input {
    border: none; background: none; outline: none;
    font-family: inherit; font-size: 13px; color: var(--ink); width: 100%;
  }
  .icon-btn {
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--sky); border: 1px solid var(--line);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; position: relative; color: var(--muted);
    transition: background .2s;
  }
  .icon-btn:hover { background: var(--line); }
  .notif-dot {
    position: absolute; top: 6px; right: 6px;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--danger); border: 1.5px solid #fff;
  }

  /* ── CONTENT ──────────────────────────────────────── */
  .content { padding: 28px 32px; flex: 1; }

  /* ── THREE-CARD ROW ───────────────────────────────── */
  .cards-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    align-items: start;
  }

  /* ── CARD BASE ────────────────────────────────────── */
  .card {
    background: var(--white);
    border-radius: 14px;
    border: 1px solid var(--line);
    overflow: hidden;
    opacity: 0;
    animation: fadeUp .5s ease forwards;
    transition: box-shadow .2s, transform .2s;
  }
  .card:hover { box-shadow: 0 8px 28px rgba(10,124,110,.1); transform: translateY(-2px); }
  .card:nth-child(1) { animation-delay: .08s; }
  .card:nth-child(2) { animation-delay: .16s; }
  .card:nth-child(3) { animation-delay: .24s; }

  .card-header {
    padding: 18px 20px 14px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--line);
  }
  .card-title { font-size: 15px; font-weight: 600; color: var(--ink); }
  .card-subtitle { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .card-action { font-size: 12px; color: var(--teal); cursor: pointer; }

  /* ── BUNDLE MODULE TILES ──────────────────────────── */
  .bundle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 18px 20px;
  }
  .module-tile {
    border-radius: 10px;
    padding: 16px;
    display: flex; flex-direction: column; gap: 6px;
    cursor: pointer;
    position: relative; overflow: hidden;
    transition: transform .15s, box-shadow .15s;
  }
  .module-tile:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.15); }
  .module-tile::after {
    content: '';
    position: absolute; top: -18px; right: -18px;
    width: 56px; height: 56px; border-radius: 50%;
    background: rgba(255,255,255,.12);
  }
  .tile-teal   { background: linear-gradient(135deg, #0A7C6E, #12A090); color: #fff; }
  .tile-amber  { background: linear-gradient(135deg, #D97706, #F4A836); color: #fff; }
  .tile-plum   { background: linear-gradient(135deg, #6C3483, #9B59B6); color: #fff; }
  .tile-slate  { background: linear-gradient(135deg, #2C3E50, #4A6274); color: #fff; }
  .tile-label  { font-size: 12px; font-weight: 600; opacity: .9; }
  .tile-count  { font-size: 28px; font-weight: 700; line-height: 1; }
  .tile-sub    { font-size: 11px; opacity: .7; }

  /* ── QUICK LINKS ──────────────────────────────────── */
  .qlink-list { padding: 6px 0; }
  .qlink-row {
    display: flex; align-items: center; gap: 12px;
    padding: 13px 20px;
    border-bottom: 1px solid var(--line);
    cursor: pointer; transition: background .12s;
  }
  .qlink-row:last-child { border-bottom: none; }
  .qlink-row:hover { background: var(--sky); }
  .qlink-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .qlink-info { flex: 1; }
  .qlink-name { font-size: 14px; font-weight: 500; }
  .qlink-desc { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .qlink-badge {
    font-size: 10px; font-weight: 600;
    padding: 3px 8px; border-radius: 20px;
  }
  .badge-green  { background: #D1F5E5; color: #1A7F50; }
  .badge-amber  { background: #FEF3C7; color: #92400E; }
  .badge-blue   { background: #DBEAFE; color: #1E40AF; }
  .badge-purple { background: #EDE9FE; color: #5B21B6; }
  .badge-orange { background: #FFEDD5; color: #C2410C; }
  .qlink-chevron { color: var(--line); font-size: 18px; }

  /* ── ACTIVITY FEED ────────────────────────────────── */
  .activity-feed { padding: 6px 0; }
  .act-item {
    display: flex; gap: 12px;
    padding: 11px 20px;
    border-bottom: 1px solid var(--line);
    cursor: pointer; transition: background .12s;
  }
  .act-item:last-child { border-bottom: none; }
  .act-item:hover { background: var(--sky); }
  .act-dot-col { display: flex; flex-direction: column; align-items: center; padding-top: 4px; }
  .act-dot {
    width: 9px; height: 9px; border-radius: 50%;
    border: 2px solid; flex-shrink: 0;
  }
  .act-line { flex: 1; width: 1px; background: var(--line); margin-top: 3px; min-height: 16px; }
  .act-body { flex: 1; }
  .act-text { font-size: 13px; line-height: 1.4; }
  .act-meta { font-size: 11px; color: var(--muted); margin-top: 3px; }

  /* ── ANIMATION ────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SCROLLBAR ────────────────────────────────────── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-thumb { background: var(--line); border-radius: 3px; }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media(max-width:900px) {
    .sidebar { width: 60px; }
    .logo-text, .nav-label, .nav-item span, .nav-badge, .user-name, .user-role { display: none; }
    .main { margin-left: 60px; }
    .nav-item { justify-content: center; padding: 12px; }
  }
</style>
</head>
