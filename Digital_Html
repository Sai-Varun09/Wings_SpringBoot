<!DOCTYPE html>
<html>
<head>

<title>TETRA Healthcare Dashboard</title>

<style>

body{
font-family: Arial;
background:#f4f7f9;
margin:0;
}

header{
background:white;
padding:20px 40px;
border-bottom:1px solid #ddd;
font-size:20px;
font-weight:bold;
color:#1a9a82;
}

.container{
padding:30px 40px;
}

/* SUMMARY CARDS */

.summary{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:25px;
}

.card{
background:white;
padding:20px;
border-radius:8px;
box-shadow:0 4px 10px rgba(0,0,0,0.05);
}

.card h3{
margin:0;
font-size:14px;
color:#777;
}

.card p{
margin:5px 0 0 0;
font-size:28px;
font-weight:bold;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:10px;
overflow:hidden;
}

th{
background:#f9fafb;
text-align:left;
padding:14px;
font-size:13px;
border-bottom:2px solid #e5e7eb;
}

td{
padding:12px;
border-bottom:1px solid #eee;
}

.checkout{
font-weight:bold;
color:#1a9a82;
}

.run{
font-weight:600;
}

.pass{
color:green;
font-weight:bold;
}

.fail{
color:red;
font-weight:bold;
}

</style>

</head>

<body>

<header>
TETRA Healthcare Dashboard
</header>

<div class="container">

<!-- SUMMARY -->
<div class="summary">

<div class="card">
<h3>Total Checkouts</h3>
<p>{{ total_checkouts }}</p>
</div>

<div class="card">
<h3>Total Passed</h3>
<p>{{ total_pass }}</p>
</div>

<div class="card">
<h3>Total Failed</h3>
<p>{{ total_fail }}</p>
</div>

<div class="card">
<h3>Adhoc Runs</h3>
<p>{{ adhoc_runs }}</p>
</div>

</div>


<table>

<thead>
<tr>
<th>Checkout Name</th>
<th>Date</th>
<th>Run</th>
<th>Time Reported</th>
<th>Status</th>
<th>Requested By</th>
<th>Email Attachment</th>
<th>Exception</th>
</tr>
</thead>

<tbody>

<!-- Alpha Clinical -->

<tr>

<td rowspan="4" class="checkout">Alpha Clinical</td>
<td rowspan="4">{{date}}</td>

<td class="run">EMC</td>
<td>{{data.alpha.emc.time}}</td>
<td class="{{data.alpha.emc.status|lower}}">
{{data.alpha.emc.status}}
</td>
<td>{{data.alpha.emc.requested}}</td>
<td>{{data.alpha.emc.file}}</td>
<td>{{data.alpha.emc.exception}}</td>

</tr>


<tr>

<td class="run">Evening</td>
<td>{{data.alpha.evening.time}}</td>
<td class="{{data.alpha.evening.status|lower}}">
{{data.alpha.evening.status}}
</td>
<td>{{data.alpha.evening.requested}}</td>
<td>{{data.alpha.evening.file}}</td>
<td>{{data.alpha.evening.exception}}</td>

</tr>


<tr>

<td class="run">ONC</td>
<td>{{data.alpha.onc.time}}</td>
<td class="{{data.alpha.onc.status|lower}}">
{{data.alpha.onc.status}}
</td>
<td>{{data.alpha.onc.requested}}</td>
<td>{{data.alpha.onc.file}}</td>
<td>{{data.alpha.onc.exception}}</td>

</tr>


<tr>

<td class="run">ADhoc</td>
<td>{{data.alpha.adhoc.time}}</td>
<td class="{{data.alpha.adhoc.status|lower}}">
{{data.alpha.adhoc.status}}
</td>
<td>{{data.alpha.adhoc.requested}}</td>
<td>{{data.alpha.adhoc.file}}</td>
<td>{{data.alpha.adhoc.exception}}</td>

</tr>


<!-- Beta Oncology -->

<tr>

<td rowspan="4" class="checkout">Beta Oncology</td>
<td rowspan="4">{{date}}</td>

<td class="run">EMC</td>
<td>{{data.beta.emc.time}}</td>
<td>{{data.beta.emc.status}}</td>
<td>{{data.beta.emc.requested}}</td>
<td>{{data.beta.emc.file}}</td>
<td>{{data.beta.emc.exception}}</td>

</tr>

<tr>
<td class="run">Evening</td>
<td>{{data.beta.evening.time}}</td>
<td>{{data.beta.evening.status}}</td>
<td>{{data.beta.evening.requested}}</td>
<td>{{data.beta.evening.file}}</td>
<td>{{data.beta.evening.exception}}</td>
</tr>

<tr>
<td class="run">ONC</td>
<td>{{data.beta.onc.time}}</td>
<td>{{data.beta.onc.status}}</td>
<td>{{data.beta.onc.requested}}</td>
<td>{{data.beta.onc.file}}</td>
<td>{{data.beta.onc.exception}}</td>
</tr>

<tr>
<td class="run">ADhoc</td>
<td>{{data.beta.adhoc.time}}</td>
<td>{{data.beta.adhoc.status}}</td>
<td>{{data.beta.adhoc.requested}}</td>
<td>{{data.beta.adhoc.file}}</td>
<td>{{data.beta.adhoc.exception}}</td>
</tr>

</tbody>

</table>

</div>

</body>
</html>
