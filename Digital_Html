<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TCS Healthcare — Clinical Operations Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --teal:      #0A7C6E;
    --teal-lt:   #12A090;
    --teal-dk:   #065248;
    --sky:       #EAF7F5;
    --accent:    #F4A836;
    --danger:    #E05252;
    --success:   #2ECC8B;
    --ink:       #0F1F1D;
    --muted:     #6B8A87;
    --line:      #D4ECEA;
    --white:     #FFFFFF;
    --card-bg:   #F7FDFC;
    --sidebar-w: 240px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--sky);
    color: var(--ink);
    min-height: 100vh;
    display: flex;
    overflow-x: hidden;
  }

  /* ── SIDEBAR ─────────────────────────────────────────── */
  .sidebar {
    width: var(--sidebar-w);
    background: var(--teal-dk);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0;
    height: 100vh;
    z-index: 100;
    transition: width .3s ease;
  }

  .sidebar-logo {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; gap: 12px;
  }
  .logo-icon {
    width: 36px; height: 36px;
    background: var(--accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: var(--ink);
    flex-shrink: 0;
  }
  .logo-text { color: #fff; font-size: 13px; line-height: 1.3; }
  .logo-text strong { display: block; font-size: 15px; letter-spacing: .3px; }

  nav { flex: 1; padding: 16px 0; overflow-y: auto; }

  .nav-section { margin-bottom: 4px; }
  .nav-label {
    font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    padding: 8px 24px 4px;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 24px;
    color: rgba(255,255,255,.65);
    text-decoration: none;
    font-size: 14px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all .2s;
  }
  .nav-item:hover, .nav-item.active {
    background: rgba(255,255,255,.07);
    color: #fff;
    border-left-color: var(--accent);
  }
  .nav-item svg { flex-shrink: 0; opacity: .8; }
  .nav-badge {
    margin-left: auto;
    background: var(--danger);
    color: #fff;
    font-size: 10px; font-weight: 600;
    padding: 2px 6px; border-radius: 10px;
  }

  .sidebar-footer {
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; gap: 10px;
  }
  .avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--teal-lt);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 600; font-size: 12px; flex-shrink: 0;
  }
  .user-info { flex: 1; }
  .user-name { color: #fff; font-size: 13px; font-weight: 500; }
  .user-role { color: rgba(255,255,255,.4); font-size: 11px; }

  /* ── MAIN ─────────────────────────────────────────────── */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── TOPBAR ──────────────────────────────────────────── */
  .topbar {
    background: var(--white);
    padding: 0 32px;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--line);
    position: sticky; top: 0; z-index: 50;
  }
  .page-title { font-family: 'Playfair Display', serif; font-size: 22px; color: var(--ink); }
  .page-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }

  .topbar-right { display: flex; align-items: center; gap: 16px; }

  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: var(--sky);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 13px; color: var(--muted);
    cursor: text; transition: border-color .2s;
    width: 200px;
  }
  .search-box:focus-within { border-color: var(--teal); }
  .search-box input {
    border: none; background: none; outline: none;
    font-family: inherit; font-size: 13px; color: var(--ink); width: 100%;
  }

  .icon-btn {
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--sky); border: 1px solid var(--line);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; position: relative; color: var(--muted);
    transition: background .2s;
  }
  .icon-btn:hover { background: var(--line); }
  .notif-dot {
    position: absolute; top: 6px; right: 6px;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--danger); border: 1.5px solid #fff;
  }

  /* ── CONTENT ──────────────────────────────────────────── */
  .content { padding: 28px 32px; flex: 1; }

  /* ── KPI STRIP ───────────────────────────────────────── */
  .kpi-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }
  .kpi-card {
    background: var(--white);
    border-radius: 14px;
    padding: 20px 22px;
    border: 1px solid var(--line);
    display: flex; flex-direction: column; gap: 6px;
    opacity: 0;
    animation: fadeUp .5s ease forwards;
    transition: box-shadow .2s;
  }
  .kpi-card:hover { box-shadow: 0 6px 24px rgba(10,124,110,.1); }
  .kpi-card:nth-child(1) { animation-delay: .05s; }
  .kpi-card:nth-child(2) { animation-delay: .1s; }
  .kpi-card:nth-child(3) { animation-delay: .15s; }
  .kpi-card:nth-child(4) { animation-delay: .2s; }

  .kpi-label { font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: .8px; color: var(--muted); }
  .kpi-value { font-size: 32px; font-weight: 600; color: var(--ink); line-height: 1; }
  .kpi-delta {
    font-size: 12px; display: flex; align-items: center; gap: 4px;
  }
  .kpi-delta.up { color: var(--success); }
  .kpi-delta.dn { color: var(--danger); }
  .kpi-icon {
    width: 38px; height: 38px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 4px;
  }

  /* ── GRID LAYOUT ─────────────────────────────────────── */
  .dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 320px;
    grid-template-rows: auto auto;
    gap: 20px;
  }

  /* ── SECTION CARD ────────────────────────────────────── */
  .card {
    background: var(--white);
    border-radius: 14px;
    border: 1px solid var(--line);
    overflow: hidden;
    opacity: 0;
    animation: fadeUp .5s ease forwards;
    transition: box-shadow .2s;
  }
  .card:hover { box-shadow: 0 6px 24px rgba(10,124,110,.08); }
  .card:nth-child(1) { animation-delay: .25s; }
  .card:nth-child(2) { animation-delay: .3s; }
  .card:nth-child(3) { animation-delay: .35s; }
  .card:nth-child(4) { animation-delay: .4s; }
  .card:nth-child(5) { animation-delay: .45s; }

  .card-header {
    padding: 18px 22px 14px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--line);
  }
  .card-title { font-weight: 600; font-size: 15px; }
  .card-subtitle { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .card-action {
    font-size: 12px; color: var(--teal); cursor: pointer;
    display: flex; align-items: center; gap: 4px;
  }
  .card-body { padding: 18px 22px; }

  /* ── BUNDLE MODULE ────────────────────────────────────── */
  .bundle-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  .module-tile {
    border-radius: 10px;
    padding: 16px;
    display: flex; flex-direction: column; gap: 8px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform .15s;
  }
  .module-tile:hover { transform: translateY(-2px); }
  .module-tile::after {
    content: '';
    position: absolute; top: -20px; right: -20px;
    width: 60px; height: 60px; border-radius: 50%;
    background: rgba(255,255,255,.15);
  }
  .module-tile.teal   { background: linear-gradient(135deg, var(--teal), var(--teal-lt)); color: #fff; }
  .module-tile.amber  { background: linear-gradient(135deg, #D97706, #F4A836); color: #fff; }
  .module-tile.plum   { background: linear-gradient(135deg, #6C3483, #9B59B6); color: #fff; }
  .module-tile.slate  { background: linear-gradient(135deg, #2C3E50, #4A6274); color: #fff; }

  .tile-label { font-size: 13px; font-weight: 600; }
  .tile-count { font-size: 26px; font-weight: 700; }
  .tile-sub   { font-size: 11px; opacity: .75; }

  /* ── DDy / EBB / DAys LINKS ──────────────────────────── */
  .quick-links { display: flex; flex-direction: column; gap: 0; }
  .qlink {
    display: flex; align-items: center;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    gap: 12px;
    cursor: pointer;
    transition: background .15s;
    border-radius: 6px;
    padding-left: 8px; padding-right: 8px;
  }
  .qlink:last-child { border-bottom: none; }
  .qlink:hover { background: var(--sky); }

  .qlink-icon {
    width: 36px; height: 36px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .qlink-title { font-size: 14px; font-weight: 500; }
  .qlink-desc  { font-size: 11px; color: var(--muted); }
  .qlink-arrow { margin-left: auto; color: var(--muted); }
  .qlink-badge {
    margin-left: 6px; font-size: 10px; font-weight: 600;
    background: var(--sky); border: 1px solid var(--line);
    padding: 2px 7px; border-radius: 10px; color: var(--teal);
  }

  /* ── CONSISTENCY TABLE ───────────────────────────────── */
  .consist-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .consist-table th {
    text-align: left; padding: 8px 10px;
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .7px; color: var(--muted);
    border-bottom: 2px solid var(--line);
  }
  .consist-table td { padding: 11px 10px; border-bottom: 1px solid var(--line); vertical-align: middle; }
  .consist-table tr:last-child td { border-bottom: none; }
  .consist-table tr:hover td { background: var(--sky); }

  .status-pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 600;
  }
  .pill-green { background: #D1F5E5; color: #1A7F50; }
  .pill-amber { background: #FEF3C7; color: #92400E; }
  .pill-red   { background: #FEE2E2; color: #9B1C1C; }
  .pill-blue  { background: #DBEAFE; color: #1E40AF; }

  .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

  /* ── PROCESS FLOW ────────────────────────────────────── */
  .process-flow { display: flex; align-items: flex-start; gap: 0; position: relative; }
  .process-step {
    flex: 1; text-align: center; padding: 0 8px;
    position: relative;
  }
  .step-circle {
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--sky); border: 2px solid var(--line);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 10px;
    font-size: 16px;
    transition: all .2s;
    cursor: pointer;
  }
  .step-circle.done  { background: var(--teal); border-color: var(--teal); color: #fff; }
  .step-circle.active { background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 0 0 4px rgba(244,168,54,.2); }

  .step-line {
    position: absolute; top: 20px; left: 50%;
    width: 100%; height: 2px; background: var(--line); z-index: 0;
  }
  .step-line.done { background: var(--teal); }

  .step-label { font-size: 11px; color: var(--muted); font-weight: 500; }
  .step-label strong { display: block; font-size: 12px; color: var(--ink); }

  /* ── ACTIVITY FEED ───────────────────────────────────── */
  .activity-feed { display: flex; flex-direction: column; gap: 0; }
  .activity-item {
    display: flex; gap: 12px; padding: 12px 0;
    border-bottom: 1px solid var(--line);
  }
  .activity-item:last-child { border-bottom: none; }
  .activity-dot-wrap { display: flex; flex-direction: column; align-items: center; padding-top: 3px; }
  .activity-dot {
    width: 10px; height: 10px; border-radius: 50%;
    border: 2px solid; flex-shrink: 0;
  }
  .activity-line { flex: 1; width: 1px; background: var(--line); margin-top: 4px; }
  .activity-body { flex: 1; }
  .activity-text { font-size: 13px; line-height: 1.4; }
  .activity-meta { font-size: 11px; color: var(--muted); margin-top: 3px; }

  /* ── PROGRESS BAR ────────────────────────────────────── */
  .progress-group { display: flex; flex-direction: column; gap: 14px; }
  .progress-item {}
  .progress-info { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px; }
  .progress-label { font-weight: 500; }
  .progress-val { color: var(--muted); font-size: 12px; }
  .progress-bar-bg {
    height: 7px; background: var(--sky); border-radius: 10px; overflow: hidden;
    border: 1px solid var(--line);
  }
  .progress-bar-fill {
    height: 100%; border-radius: 10px;
    transition: width 1s cubic-bezier(.4,0,.2,1);
  }

  /* ── SPAN HELPERS ────────────────────────────────────── */
  .span-2 { grid-column: span 2; }
  .span-full { grid-column: 1 / -1; }

  /* ── MINI CHART ──────────────────────────────────────── */
  canvas.minichart { width: 100%; height: 100px; display: block; }

  /* ── BANNER ──────────────────────────────────────────── */
  .banner {
    background: linear-gradient(135deg, var(--teal-dk), var(--teal));
    border-radius: 14px;
    padding: 20px 28px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp .5s .02s ease forwards;
    color: #fff;
  }
  .banner-text h2 { font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 4px; }
  .banner-text p  { font-size: 13px; opacity: .75; }
  .banner-stats { display: flex; gap: 28px; }
  .banner-stat { text-align: center; }
  .banner-stat .bval { font-size: 28px; font-weight: 700; }
  .banner-stat .blbl { font-size: 11px; opacity: .65; text-transform: uppercase; letter-spacing: .8px; }

  /* ── ANIMATIONS ──────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SCROLLBAR ───────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--line); border-radius: 3px; }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media(max-width:1100px){
    .dashboard-grid { grid-template-columns: 1fr 1fr; }
    .kpi-strip { grid-template-columns: repeat(2,1fr); }
  }
  @media(max-width:720px){
    .sidebar { width: 64px; }
    .sidebar-logo .logo-text, .nav-label, .nav-item span, .sidebar-footer .user-info { display: none; }
    .main { margin-left: 64px; }
    .dashboard-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
