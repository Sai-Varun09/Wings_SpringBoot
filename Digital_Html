<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TETRA Healthcare Dashboard</title>

<style>

:root{
--primary:#1a9a82;
--pass:#2e7d32;
--fail:#d32f2f;
--adhoc:#1565c0;
--bg:#f4f7f9;
--border:#e5e7eb;
--text:#1f2937;
--white:#ffffff;
}

body{
font-family: Arial, Helvetica, sans-serif;
background:var(--bg);
margin:0;
}

/* HEADER */

header{
background:white;
height:70px;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 40px;
border-bottom:1px solid var(--border);
}

.logo{
font-size:20px;
font-weight:700;
color:var(--primary);
}

/* DASHBOARD */

.container{
padding:30px 40px;
}

/* SUMMARY CARDS */

.summary{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:25px;
}

.card{
background:white;
border-radius:10px;
padding:20px;
box-shadow:0 5px 15px rgba(0,0,0,0.05);
border-left:6px solid var(--primary);
}

.card h3{
margin:0;
font-size:14px;
color:#6b7280;
}

.card p{
margin:5px 0 0 0;
font-size:28px;
font-weight:700;
}

.pass{border-left-color:var(--pass);}
.fail{border-left-color:var(--fail);}
.adhoc{border-left-color:var(--adhoc);}

/* TABLE */

.table-container{
background:white;
border-radius:12px;
overflow:hidden;
box-shadow:0 10px 25px rgba(0,0,0,0.05);
border:1px solid var(--border);
}

table{
width:100%;
border-collapse:collapse;
}

thead{
background:#f9fafb;
}

th{
text-align:left;
padding:15px;
font-size:13px;
color:#6b7280;
border-bottom:2px solid var(--border);
}

td{
padding:14px;
border-bottom:1px solid #f1f1f1;
font-size:14px;
}

.checkout{
font-weight:700;
color:var(--primary);
}

.status-pass{
color:var(--pass);
font-weight:700;
}

.status-fail{
color:var(--fail);
font-weight:700;
}

.run{
font-weight:600;
}

tbody tr:hover{
background:#f8fbfb;
}

</style>
</head>

<body>

<header>
<div class="logo">TETRA Healthcare Dashboard</div>
</header>

<div class="container">

<!-- SUMMARY -->

<div class="summary">

<div class="card">
<h3>Total Checkouts</h3>
<p id="totalCheckouts">0</p>
</div>

<div class="card pass">
<h3>Total Passed</h3>
<p id="totalPass">0</p>
</div>

<div class="card fail">
<h3>Total Failed</h3>
<p id="totalFail">0</p>
</div>

<div class="card adhoc">
<h3>Adhoc Runs</h3>
<p id="adhocRuns">0</p>
</div>

</div>

<!-- TABLE -->

<div class="table-container">

<table>

<thead>
<tr>
<th>Checkout Name</th>
<th>Date</th>
<th>Run</th>
<th>Time Reported</th>
<th>Status</th>
<th>Requested By</th>
<th>Email Attachment</th>
<th>Exception</th>
</tr>
</thead>

<tbody id="tableBody">

<!-- Flask will generate rows here -->

{% for row in data %}

<tr>
<td class="checkout" rowspan="4">{{row.checkout}}</td>
<td rowspan="4">{{row.date}}</td>

<td class="run">EMC</td>
<td>{{row.emc_time}}</td>
<td class="status-{{row.emc_status | lower}}">{{row.emc_status}}</td>
<td>{{row.requested_by}}</td>
<td>{{row.emc_attachment}}</td>
<td>{{row.emc_exception}}</td>
</tr>

<tr>
<td class="run">Evening</td>
<td>{{row.evening_time}}</td>
<td class="status-{{row.evening_status | lower}}">{{row.evening_status}}</td>
<td>{{row.requested_by}}</td>
<td>{{row.evening_attachment}}</td>
<td>{{row.evening_exception}}</td>
</tr>

<tr>
<td class="run">ONC</td>
<td>{{row.onc_time}}</td>
<td class="status-{{row.onc_status | lower}}">{{row.onc_status}}</td>
<td>{{row.requested_by}}</td>
<td>{{row.onc_attachment}}</td>
<td>{{row.onc_exception}}</td>
</tr>

<tr>
<td class="run">ADhoc</td>
<td>{{row.adhoc_time}}</td>
<td class="status-{{row.adhoc_status | lower}}">{{row.adhoc_status}}</td>
<td>{{row.requested_by}}</td>
<td>{{row.adhoc_attachment}}</td>
<td>{{row.adhoc_exception}}</td>
</tr>

{% endfor %}

</tbody>

</table>

</div>

</div>

</body>
</html>
