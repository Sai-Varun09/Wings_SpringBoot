<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<script>
/* ────────────────────────────────────────────────────────
   DATA
──────────────────────────────────────────────────────── */
const activities = [
  { color: '#1A7F50', border: '#D1F5E5', text: 'Bundle <strong>BAM-024</strong> assigned — Ward 3B', time: '2 min ago', tag: 'Bundle' },
  { color: '#92400E', border: '#FEF3C7', text: 'EBB claim <strong>#8821</strong> flagged for review', time: '14 min ago', tag: 'EBB' },
  { color: '#1E40AF', border: '#DBEAFE', text: 'DAys score updated for patient <strong>P-0044</strong>', time: '31 min ago', tag: 'DAys' },
  { color: '#6C3483', border: '#EDE9FE', text: 'ECM document <strong>MR-2026-0312</strong> uploaded', time: '52 min ago', tag: 'ECM' },
  { color: '#1A7F50', border: '#D1F5E5', text: 'DDy portal: 3 results cleared for discharge', time: '1 hr ago', tag: 'DDy' },
  { color: '#9B1C1C', border: '#FEE2E2', text: 'CRITICAL: ICU bed occupancy at 94%', time: '1.5 hr ago', tag: 'Alert' },
  { color: '#92400E', border: '#FEF3C7', text: 'BAM allocation recalculated — 6 moves', time: '2 hr ago', tag: 'BAM' },
  { color: '#1E40AF', border: '#DBEAFE', text: 'ECM audit trail generated for Q1 2026', time: '3 hr ago', tag: 'ECM' },
];

const consistData = [
  { dept:'ICU',        protocol:'Sepsis Bundle',    adherence:'97%', status:'pill-green', label:'Compliant' },
  { dept:'Cardiology', protocol:'ACS Pathway',      adherence:'89%', status:'pill-amber', label:'Review' },
  { dept:'Oncology',   protocol:'Chemo Safety',     adherence:'100%',status:'pill-green', label:'Compliant' },
  { dept:'Paediatrics',protocol:'VAP Bundle',       adherence:'72%', status:'pill-red',   label:'At Risk' },
  { dept:'Emergency',  protocol:'Triage Protocol',  adherence:'95%', status:'pill-green', label:'Compliant' },
  { dept:'Surgery',    protocol:'WHO Checklist',    adherence:'83%', status:'pill-amber', label:'Review' },
];

const processSteps = [
  { label:'Triage', sub:'Registration', state:'done' },
  { label:'Assessment', sub:'DDy Check', state:'done' },
  { label:'Admission', sub:'BAM Assign', state:'done' },
  { label:'Treatment', sub:'Active', state:'active' },
  { label:'Review', sub:'EBB Score', state:'' },
  { label:'Discharge', sub:'ECM Final', state:'' },
];

const progressData = [
  { label:'Bundle Completion', val:78,  color:'var(--teal)' },
  { label:'ECM Filing',        val:91,  color:'var(--success)' },
  { label:'EBB Reconciliation',val:64,  color:'var(--accent)' },
  { label:'DAys Scoring',      val:55,  color:'#9B59B6' },
];

/* ────────────────────────────────────────────────────────
   RENDER ACTIVITY FEED
──────────────────────────────────────────────────────── */
const feed = document.getElementById('activityFeed');
activities.forEach((a, i) => {
  const isLast = i === activities.length - 1;
  feed.innerHTML += `
    <div class="activity-item">
      <div class="activity-dot-wrap">
        <div class="activity-dot" style="border-color:${a.color};background:${a.border}"></div>
        ${!isLast ? '<div class="activity-line"></div>' : ''}
      </div>
      <div class="activity-body">
        <div class="activity-text">${a.text}</div>
        <div class="activity-meta">${a.tag} · ${a.time}</div>
      </div>
    </div>`;
});

/* ────────────────────────────────────────────────────────
   RENDER CONSISTENCY TABLE
──────────────────────────────────────────────────────── */
const tbody = document.getElementById('consistTable');
consistData.forEach(r => {
  tbody.innerHTML += `
    <tr>
      <td style="font-weight:500">${r.dept}</td>
      <td style="color:var(--muted)">${r.protocol}</td>
      <td style="font-weight:600">${r.adherence}</td>
      <td><span class="status-pill ${r.status}"><span class="dot"></span>${r.label}</span></td>
    </tr>`;
});

/* ────────────────────────────────────────────────────────
   RENDER PROCESS FLOW
──────────────────────────────────────────────────────── */
const pf = document.getElementById('processFlow');
processSteps.forEach((s, i) => {
  const cls = s.state === 'done' ? 'done' : s.state === 'active' ? 'active' : '';
  const lineCls = s.state === 'done' ? 'done' : '';
  pf.innerHTML += `
    <div class="process-step">
      ${i < processSteps.length - 1 ? `<div class="step-line ${lineCls}"></div>` : ''}
      <div class="step-circle ${cls}" style="position:relative;z-index:1;">
        ${s.state === 'done' ? '✓' : s.state === 'active' ? '●' : String(i+1)}
      </div>
      <div class="step-label"><strong>${s.label}</strong>${s.sub}</div>
    </div>`;
});

/* ────────────────────────────────────────────────────────
   RENDER PROGRESS BARS
──────────────────────────────────────────────────────── */
const pg = document.getElementById('progressGroup');
progressData.forEach(p => {
  pg.innerHTML += `
    <div class="progress-item">
      <div class="progress-info">
        <span class="progress-label">${p.label}</span>
        <span class="progress-val">${p.val}%</span>
      </div>
      <div class="progress-bar-bg">
        <div class="progress-bar-fill" style="width:0%;background:${p.color}" data-val="${p.val}"></div>
      </div>
    </div>`;
});

/* Animate bars on load */
setTimeout(() => {
  document.querySelectorAll('.progress-bar-fill').forEach(el => {
    el.style.width = el.dataset.val + '%';
  });
}, 400);

/* ────────────────────────────────────────────────────────
   MINI CHART
──────────────────────────────────────────────────────── */
const ctx = document.getElementById('miniChart').getContext('2d');
new Chart(ctx, {
  type: 'line',
  data: {
    labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
    datasets: [
      {
        label: 'BAM', data: [14,18,15,22,19,16,18],
        borderColor: '#0A7C6E', backgroundColor: 'rgba(10,124,110,.08)',
        tension: .4, fill: true, pointRadius: 3
      },
      {
        label: 'EBB', data: [8,10,13,9,11,14,11],
        borderColor: '#F4A836', backgroundColor: 'rgba(244,168,54,.06)',
        tension: .4, fill: true, pointRadius: 3
      },
    ]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { display: false }, ticks: { font: { size: 10 }, color: '#6B8A87' } },
      y: { display: false }
    }
  }
});

/* ────────────────────────────────────────────────────────
   LIVE CLOCK in topbar
──────────────────────────────────────────────────────── */
function updateClock() {
  const now = new Date();
  const sub = document.querySelector('.page-sub');
  if(sub) {
    const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    sub.textContent = `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()} · ${now.toLocaleTimeString()} · General Hospital Network`;
  }
}
updateClock();
setInterval(updateClock, 1000);

/* ────────────────────────────────────────────────────────
   NAV INTERACTION
──────────────────────────────────────────────────────── */
document.querySelectorAll('.nav-item').forEach(item => {
  item.addEventListener('click', () => {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    item.classList.add('active');
  });
});
</script>
