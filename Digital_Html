<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>TETRA Healthcare Dashboard</title>

<style>

:root{
--primary:#1a9a82;
--pass:#16a34a;
--fail:#dc2626;
--bg:#f4f7f9;
--card:#ffffff;
--border:#e5e7eb;
--text:#111827;
}

body{
font-family: Arial, Helvetica, sans-serif;
background:var(--bg);
margin:0;
}

header{
height:70px;
background:white;
border-bottom:1px solid var(--border);
display:flex;
align-items:center;
justify-content:space-between;
padding:0 40px;
}

.logo{
font-weight:700;
color:var(--primary);
font-size:20px;
}

.dashboard{
padding:100px 40px 40px;
max-width:1500px;
margin:auto;
}

/* SUMMARY CARDS */

.summary{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:30px;
}

.card{
background:var(--card);
padding:20px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.05);
border:1px solid var(--border);
}

.card h3{
margin:0;
font-size:14px;
color:#6b7280;
}

.card p{
font-size:28px;
font-weight:700;
margin-top:10px;
}

.pass-card p{color:var(--pass)}
.fail-card p{color:var(--fail)}
.adhoc-card p{color:#2563eb}

/* TABLE */

.table-container{
background:white;
border-radius:10px;
border:1px solid var(--border);
overflow:auto;
max-height:600px;
}

table{
width:100%;
border-collapse:collapse;
}

thead{
background:#f9fafb;
position:sticky;
top:0;
}

th{
padding:14px;
font-size:13px;
text-align:left;
border-bottom:2px solid var(--border);
}

td{
padding:12px;
border-bottom:1px solid #f1f5f9;
font-size:14px;
}

.pass{
color:var(--pass);
font-weight:700;
}

.fail{
color:var(--fail);
font-weight:700;
}

</style>
</head>

<body>

<header>
<div class="logo">TETRA Healthcare</div>
</header>

<div class="dashboard">

<!-- SUMMARY -->
<div class="summary">

<div class="card">
<h3>Total Checkouts</h3>
<p id="totalCount">0</p>
</div>

<div class="card pass-card">
<h3>Total Passed</h3>
<p id="passCount">0</p>
</div>

<div class="card fail-card">
<h3>Total Failed</h3>
<p id="failCount">0</p>
</div>

<div class="card adhoc-card">
<h3>Adhoc Runs</h3>
<p id="adhocCount">0</p>
</div>

</div>

<!-- TABLE -->

<div class="table-container">

<table>

<thead>
<tr>
<th>Checkout Name</th>
<th>Date</th>
<th>Run</th>
<th>Time Reported</th>
<th>Status</th>
<th>Requested By</th>
<th>Email Attachment</th>
<th>Exception</th>
</tr>
</thead>

<tbody id="tableBody">
</tbody>

</table>

</div>

</div>

<script>

fetch("/get-data")
.then(res => res.json())
.then(data => {

let tbody=document.getElementById("tableBody")

let pass=0
let fail=0
let adhoc=0

data.forEach(row=>{

let tr=document.createElement("tr")

if(row.status==="Pass") pass++
if(row.status==="Fail") fail++
if(row.run.toLowerCase()==="adhoc") adhoc++

tr.innerHTML=`

<td>${row.checkout_name}</td>
<td>${row.date}</td>
<td>${row.run}</td>
<td>${row.time}</td>
<td class="${row.status==='Pass'?'pass':'fail'}">${row.status}</td>
<td>${row.requested_by}</td>
<td>${row.attachment}</td>
<td>${row.exception}</td>

`

tbody.appendChild(tr)

})

document.getElementById("totalCount").innerText=data.length
document.getElementById("passCount").innerText=pass
document.getElementById("failCount").innerText=fail
document.getElementById("adhocCount").innerText=adhoc

})

</script>

</body>
</html>
